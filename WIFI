<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <title>Wi-Fi Guest Access</title>
    <script>
        // Zachytenie URL parametrov od Meraki
        const urlParams = new URLSearchParams(window.location.search);
        const baseGrantUrl = urlParams.get('base_grant_url');
        const userContinueUrl = urlParams.get('user_continue_url');

        function connect(lang) {
            // Tu môžete logovať výber jazyka
            // Presmerovanie späť na Meraki pre autorizáciu
            window.location.href = baseGrantUrl + "?continue_url=" + encodeURIComponent(userContinueUrl);
        }

        function switchLang(lang) {
            document.querySelectorAll('.lang-section').forEach(div => div.style.display = 'none');
            document.getElementById('lang-' + lang).style.display = 'block';
        }
    </script>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 50px; }
        .lang-section { display: none; }
        button { padding: 15px 30px; font-size: 18px; cursor: pointer; border-radius: 5px; }
    </style>
</head>
<body onload="switchLang('sk')">
    <img src="logo.png" alt="Logo" width="200">
    
    <div>
        <a href="#" onclick="switchLang('sk')">SK</a> | 
        <a href="#" onclick="switchLang('en')">EN</a>
    </div>

    <div id="lang-sk" class="lang-section" style="display:block;">
        <h1>Vitajte v našej sieti</h1>
        <p>Kliknutím na tlačidlo súhlasíte s podmienkami.</p>
        <button onclick="connect('sk')">Pripojiť sa</button>
    </div>

    <div id="lang-en" class="lang-section">
        <h1>Welcome to our network</h1>
        <p>By clicking the button you agree to the terms.</p>
        <button onclick="connect('en')">Connect</button>
    </div>
</body>
</html>
